<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CareerMind AI — AI-Powered Resume Intelligence Platform</title>
  
  <!-- Modern Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- FontAwesome Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- Premium Dark Mode Theme Stylesheet -->
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

  <!-- Toast Notification System -->
  <% if session[:error] %>
    <div class="toast-notification toast-error" id="session-toast">
      <i class="fa-solid fa-circle-exclamation"></i>
      <span><%= session.delete(:error) %></span>
      <button onclick="document.getElementById('session-toast').remove()">&times;</button>
    </div>
  <% end %>

  <% if session[:success] %>
    <div class="toast-notification toast-success" id="session-toast">
      <i class="fa-solid fa-circle-check"></i>
      <span><%= session.delete(:success) %></span>
      <button onclick="document.getElementById('session-toast').remove()">&times;</button>
    </div>
  <% end %>

  <!-- Main Container -->
  <div class="app-wrapper">
    <%= yield %>
  </div>

</body>
</html>

<script src="/js/charts.js"></script>
<script>
// Tab Switching logic
function switchTab(button, tabId) {
  document.querySelectorAll('.tab-content').forEach(el => {
    el.style.display = 'none';
  });
  
  document.getElementById(tabId).style.display = 'block';
  
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.classList.remove('active');
  });
  button.classList.add('active');
  
  if (tabId === 'tab-chat') {
    const chatBox = document.getElementById('chat-box');
    chatBox.scrollTop = chatBox.scrollHeight;
  }
}

// Collapsible answers logic
function toggleAnswer(button) {
  const content = button.parentNode.nextElementSibling;
  
  if (content.style.display === 'none') {
    content.style.display = 'block';
    button.innerHTML = '<i class="fa-solid fa-eye-slash"></i> <%= current_locale == "tr" ? "Cevabı Gizle" : "Hide Response" %>';
  } else {
    content.style.display = 'none';
    button.innerHTML = '<i class="fa-solid fa-eye"></i> <%= current_locale == "tr" ? "Önerilen Cevabı Göster" : "Reveal Suggested Response" %>';
  }
}

// Copy guide comparison texts
function copyText(button, key) {
  const textEl = document.getElementById('guide-text-' + key);
  if (!textEl) return;
  const textToCopy = textEl.innerText;
  
  navigator.clipboard.writeText(textToCopy).then(() => {
    const label = button.querySelector('.copy-text-lbl');
    const icon = button.querySelector('i');
    const originalText = label.innerText;
    
    label.innerText = '<%= current_locale == "tr" ? "Kopyalandı!" : "Copied!" %>';
    icon.className = "fa-solid fa-check text-green";
    
    setTimeout(() => {
      label.innerText = originalText;
      icon.className = "fa-regular fa-copy";
    }, 2000);
  }).catch(err => {
    console.error('Failed to copy text: ', err);
  });
}

// Copy interview answers texts
function copyPrepText(button, idx) {
  const textEl = document.getElementById('prep-text-' + idx);
  if (!textEl) return;
  const textToCopy = textEl.innerText;
  
  navigator.clipboard.writeText(textToCopy).then(() => {
    const label = button.querySelector('.copy-text-lbl');
    const icon = button.querySelector('i');
    const originalText = label.innerText;
    
    label.innerText = '<%= current_locale == "tr" ? "Kopyalandı!" : "Copied!" %>';
    icon.className = "fa-solid fa-check text-green";
    
    setTimeout(() => {
      label.innerText = originalText;
      icon.className = "fa-regular fa-copy";
    }, 2000);
  }).catch(err => {
    console.error('Failed to copy text: ', err);
  });
}

// Settings Toggle Panel
function toggleSettingsPanel() {
  const content = document.getElementById('sidebar-settings-content');
  const chevron = document.getElementById('settings-chevron');
  if (content.style.display === 'none') {
    content.style.display = 'block';
    chevron.style.transform = 'rotate(180deg)';
  } else {
    content.style.display = 'none';
    chevron.style.transform = 'rotate(0deg)';
  }
}

function toggleKeyFields(val) {
  document.querySelectorAll('.key-field').forEach(el => el.style.display = 'none');
  if (val !== 'local') {
    const field = document.getElementById('key-field-' + val);
    if (field) field.style.display = 'flex';
  }
}

// Avatar upload overrides
function triggerAvatarUpload() {
  document.getElementById('avatar-file-input').click();
}
function submitAvatarForm() {
  document.getElementById('avatar-upload-form').submit();
}

// Chatbot events
function sendSuggestedMessage(text) {
  document.getElementById('chat-message-input').value = text;
  submitChatMessage();
}
function handleChatKeyPress(e) {
  if (e.key === 'Enter') {
    submitChatMessage();
  }
}
function submitChatMessage() {
  const input = document.getElementById('chat-message-input');
  const message = input.value.trim();
  if (!message) return;
  input.value = '';
  
  const chatBox = document.getElementById('chat-box');
  
  // User bubble
  const userMsg = document.createElement('div');
  userMsg.className = 'message message-user';
  userMsg.style.cssText = 'display: flex; gap: 12px; max-width: 85%; align-self: flex-end; flex-direction: row-reverse;';
  userMsg.innerHTML = `
    <div class="message-avatar" style="width: 32px; height: 32px; border-radius: 50%; background: rgba(6, 182, 212, 0.15); display: flex; align-items: center; justify-content: center; font-size: 0.9rem; color: var(--accent-cyan);"><i class="fa-solid fa-user"></i></div>
    <div class="message-content" style="background: rgba(6, 182, 212, 0.08); border: 1px solid rgba(6, 182, 212, 0.15); padding: 10px 14px; border-radius: 12px 12px 0 12px; font-size: 0.85rem; color: var(--text-primary); line-height: 1.4;">
      <p>${escapeHtml(message)}</p>
    </div>
  `;
  chatBox.appendChild(userMsg);
  chatBox.scrollTop = chatBox.scrollHeight;
  
  // Loading loader
  const typingMsg = document.createElement('div');
  typingMsg.className = 'message message-assistant typing-indicator-msg';
  typingMsg.style.cssText = 'display: flex; gap: 12px; max-width: 85%;';
  typingMsg.innerHTML = `
    <div class="message-avatar" style="width: 32px; height: 32px; border-radius: 50%; background: rgba(99, 102, 241, 0.15); display: flex; align-items: center; justify-content: center; font-size: 0.9rem; color: var(--primary);"><i class="fa-solid fa-brain"></i></div>
    <div class="message-content" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.05); padding: 12px 16px; border-radius: 12px 12px 12px 0;">
      <div class="typing-loader" style="display: flex; gap: 4px; align-items: center; justify-content: center; height: 12px;">
        <span style="width: 6px; height: 6px; background: var(--text-secondary); border-radius: 50%; animation: chatPulse 1.2s infinite ease-in-out;"></span>
        <span style="width: 6px; height: 6px; background: var(--text-secondary); border-radius: 50%; animation: chatPulse 1.2s infinite ease-in-out; animation-delay: 0.2s;"></span>
        <span style="width: 6px; height: 6px; background: var(--text-secondary); border-radius: 50%; animation: chatPulse 1.2s infinite ease-in-out; animation-delay: 0.4s;"></span>
      </div>
    </div>
  `;
  chatBox.appendChild(typingMsg);
  chatBox.scrollTop = chatBox.scrollHeight;
  
  fetch('/dashboard/<%= @record.id %>/chat', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: 'message=' + encodeURIComponent(message)
  })
  .then(res => res.json())
  .then(data => {
    typingMsg.remove();
    
    const assistantMsg = document.createElement('div');
    assistantMsg.className = 'message message-assistant';
    assistantMsg.style.cssText = 'display: flex; gap: 12px; max-width: 85%;';
    assistantMsg.innerHTML = `
      <div class="message-avatar" style="width: 32px; height: 32px; border-radius: 50%; background: rgba(99, 102, 241, 0.15); display: flex; align-items: center; justify-content: center; font-size: 0.9rem; color: var(--primary);"><i class="fa-solid fa-brain"></i></div>
      <div class="message-content" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.05); padding: 10px 14px; border-radius: 12px 12px 12px 0; font-size: 0.85rem; color: var(--text-primary); line-height: 1.4;">
        <p>${escapeHtml(data.response).replace(/\n/g, '<br>')}</p>
      </div>
    `;
    chatBox.appendChild(assistantMsg);
    chatBox.scrollTop = chatBox.scrollHeight;
  })
  .catch(err => {
    console.error(err);
    typingMsg.remove();
  });
}

// Mock Interview Sim Practice Panel Toggle
function openPracticeSimulator(btn, idx) {
  const panel = document.getElementById('practice-panel-' + idx);
  if (panel.style.display === 'none') {
    panel.style.display = 'block';
    btn.innerHTML = '<i class="fa-solid fa-microphone-slash"></i> <%= current_locale == "tr" ? "Simülasyonu Kapat" : "Close Simulation" %>';
    btn.className = 'btn btn-secondary';
  } else {
    panel.style.display = 'none';
    btn.innerHTML = '<i class="fa-solid fa-microphone"></i> <%= current_locale == "tr" ? "Bu Soruyu Yanıtla (Pratik)" : "Practice This Question" %>';
    btn.className = 'btn btn-primary';
  }
}

// Mock Interview Answer AJAX Grading
function submitPracticeAnswer(btn, idx) {
  const panel = document.getElementById('practice-panel-' + idx);
  const textarea = panel.querySelector('.practice-answer-textarea');
  const text = textarea.value.trim();
  if (!text) return;
  
  const spinner = panel.querySelector('.practice-spinner');
  const resultsBox = panel.querySelector('.practice-results-box');
  
  resultsBox.style.display = 'none';
  spinner.style.display = 'block';
  btn.disabled = true;
  
  const card = panel.closest('.interview-card');
  const questionText = card.querySelector('h4').innerText;
  
  fetch('/dashboard/<%= @record.id %>/interview/evaluate', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: 'question=' + encodeURIComponent(questionText) + '&answer=' + encodeURIComponent(text)
  })
  .then(res => res.json())
  .then(data => {
    spinner.style.display = 'none';
    btn.disabled = false;
    
    // Set grading results
    panel.querySelector('.practice-score-value').innerText = data.score;
    
    // Strengths
    const strengthsContainer = panel.querySelector('.practice-strengths-list');
    strengthsContainer.innerHTML = '';
    data.strengths.forEach(s => {
      const li = document.createElement('li');
      li.innerHTML = `<i class="fa-solid fa-check text-green" style="margin-right: 6px;"></i> ${escapeHtml(s)}`;
      strengthsContainer.appendChild(li);
    });
    
    // Gaps
    const gapsContainer = panel.querySelector('.practice-gaps-list');
    gapsContainer.innerHTML = '';
    data.gaps.forEach(g => {
      const li = document.createElement('li');
      li.innerHTML = `<i class="fa-solid fa-xmark text-yellow" style="margin-right: 6px;"></i> ${escapeHtml(g)}`;
      gapsContainer.appendChild(li);
    });
    
    // Refined Answer Text
    panel.querySelector('.practice-refined-box').innerText = data.refined_answer;
    
    resultsBox.style.display = 'block';
  })
  .catch(err => {
    console.error(err);
    spinner.style.display = 'none';
    btn.disabled = false;
  });
}

// Job Matcher AJAX Alignment
function runJobMatcher() {
  const textarea = document.getElementById('job-desc-textarea');
  const text = textarea.value.trim();
  if (!text) return;
  
  const btn = document.getElementById('run-matcher-btn');
  const spinner = document.getElementById('matcher-loading');
  const resultsBox = document.getElementById('matcher-results');
  
  btn.disabled = true;
  spinner.style.display = 'block';
  resultsBox.style.display = 'none';
  
  fetch('/dashboard/<%= @record.id %>/match_job', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: 'job_description=' + encodeURIComponent(text)
  })
  .then(res => res.json())
  .then(data => {
    spinner.style.display = 'none';
    btn.disabled = false;
    
    // Matcher Score text
    document.getElementById('match-pct-value').innerText = data.score;
    
    // Render matching tags
    const matchedContainer = document.getElementById('matched-kws-container');
    matchedContainer.innerHTML = '';
    if (data.matched_keywords.length === 0) {
      matchedContainer.innerHTML = '<span style="font-size: 0.8rem; color: var(--text-muted);">None found</span>';
    } else {
      data.matched_keywords.forEach(kw => {
        const span = document.createElement('span');
        span.className = 'tag tag-matched';
        span.innerText = kw;
        matchedContainer.appendChild(span);
      });
    }
    
    // Render missing tags
    const missingContainer = document.getElementById('missing-kws-container');
    missingContainer.innerHTML = '';
    if (data.missing_keywords.length === 0) {
      missingContainer.innerHTML = '<span style="font-size: 0.8rem; color: var(--secondary);"><i class="fa-solid fa-circle-check"></i> Complete match!</span>';
    } else {
      data.missing_keywords.forEach(kw => {
        const span = document.createElement('span');
        span.className = 'tag tag-gap';
        span.innerText = kw;
        missingContainer.appendChild(span);
      });
    }
    
    // Tailoring instructions list
    const suggestionsContainer = document.getElementById('tailoring-suggestions-container');
    suggestionsContainer.innerHTML = '';
    data.tailoring_suggestions.forEach(sug => {
      const li = document.createElement('li');
      li.style.cssText = 'font-size: 0.85rem; color: var(--text-primary); line-height: 1.4; display: flex; gap: 8px; align-items: flex-start;';
      li.innerHTML = `<i class="fa-solid fa-wand-magic-sparkles text-purple" style="margin-top: 3px;"></i> <span>${escapeHtml(sug)}</span>`;
      suggestionsContainer.appendChild(li);
    });
    
    resultsBox.style.display = 'block';
    
    // Draw canvas gauge
    setTimeout(() => {
      drawMiniGauge('matcher-gauge-canvas', data.score);
    }, 100);
  })
  .catch(err => {
    console.error(err);
    spinner.style.display = 'none';
    btn.disabled = false;
  });
}

function drawMiniGauge(canvasId, pct) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const cx = canvas.width / 2;
  const cy = canvas.height / 2;
  const radius = 48;
  
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  
  // Track ring background
  ctx.beginPath();
  ctx.arc(cx, cy, radius, 0, Math.PI * 2);
  ctx.strokeStyle = 'rgba(255, 255, 255, 0.04)';
  ctx.lineWidth = 6;
  ctx.stroke();
  
  // Active gauge stroke
  ctx.beginPath();
  const startAngle = -Math.PI / 2;
  const endAngle = startAngle + (Math.PI * 2 * (pct / 100));
  ctx.arc(cx, cy, radius, startAngle, endAngle);
  ctx.strokeStyle = pct >= 80 ? '#10b981' : (pct >= 60 ? '#f59e0b' : '#ef4444');
  ctx.lineWidth = 6;
  ctx.lineCap = 'round';
  ctx.stroke();
}

function escapeHtml(text) {
  return text
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#039;");
}
</script>
